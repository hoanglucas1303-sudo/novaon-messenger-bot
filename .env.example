# ==== Facebook Messenger (Phase 0) ====
# Token trang lấy từ Meta App > Messenger > Generate Token (gắn với Fanpage test)
PAGE_ACCESS_TOKEN=
# Chuỗi bí mật tự đặt, khai báo TRÙNG với ô "Verify Token" khi cấu hình Webhook trên Meta
VERIFY_TOKEN=novaon-messenger-verify-2026
# App Secret lấy ở Meta App > Settings > Basic (để verify chữ ký webhook — nên có, có thể để trống lúc test)
APP_SECRET=

# ==== Server ====
PORT=3010
PUBLIC_BASE_URL=https://novaon-messenger-bot-production.up.railway.app

# ==== LLM (Phase 1+) ====
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-haiku-4.5
PREMIUM_LLM_MODEL=anthropic/claude-sonnet-4.6
LLM_MAX_TOKENS=350

# ==== DB + Lead dashboard (v1) ====
# Railway Postgres sẽ tự cấp DATABASE_URL khi gắn database vào service
DATABASE_URL=
# Basic Auth cho /leads. Bắt buộc đặt password trên production để tránh lộ SĐT khách.
DASHBOARD_USER=novaon
DASHBOARD_PASSWORD=
