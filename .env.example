# ==== Facebook Messenger (Phase 0) ====
# Token trang lấy từ Meta App > Messenger > Generate Token (gắn với Fanpage test)
PAGE_ACCESS_TOKEN=
# Chuỗi bí mật tự đặt, khai báo TRÙNG với ô "Verify Token" khi cấu hình Webhook trên Meta
VERIFY_TOKEN=novaon-messenger-verify-2026
# App Secret lấy ở Meta App > Settings > Basic (để verify chữ ký webhook — nên có, có thể để trống lúc test)
APP_SECRET=

# ==== Server ====
PORT=3010

# ==== LLM (Phase 1 — chưa dùng ở Phase 0) ====
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4.6
